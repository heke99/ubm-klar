# =============================================================================
# UBM Klar environment example
#
# Never commit real secrets. Values here are placeholders/examples only.
#
# Environment mode is controlled by APP_ENV: local | demo | test | stage | prod
# (NODE_ENV=production maps to prod when APP_ENV is unset).
#
# Rules:
#   - local/demo/test: everything below is optional; safe defaults apply
#     (in-memory stores, local storage, demo tenant, synthetic demo data).
#   - stage/prod: every variable marked [MANDATORY stage/prod] must be set and
#     unsafe providers are refused at startup (fail closed). See
#     packages/config/src/app-config.ts for the exact rules.
# =============================================================================

# --- Core ---------------------------------------------------------------------
APP_ENV=local
APP_NAME="UBM Klar"
# [MANDATORY stage/prod] canonical origins
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# =============================================================================
# LOCAL SECTION — developer machines
# Nothing below is required. Start the apps and everything defaults to safe
# local behaviour: demo tenant on localhost, in-memory stores, demo data on.
# =============================================================================
# DEMO_DATA_ENABLED=true            # default true in local/demo
# ALLOW_DEMO_TENANT=true            # default true outside stage/prod
# CONTROL_PLANE_STORE=in-memory     # default when no database URL is set
# DOCUMENT_STORAGE_PROVIDER=local
# MALWARE_SCANNER_PROVIDER=disabled-local
# QUEUE_PROVIDER=in-memory

# =============================================================================
# DEMO SECTION — synthetic-data demo deployments
# Same defaults as local. Demo deployments must stay clearly marked as demo:
# =============================================================================
# APP_ENV=demo
# DEMO_DATA_ENABLED=true
# DEPLOYMENT_MODE=local_demo_shared # allowed here, forbidden in stage/prod

# =============================================================================
# STAGE/PROD SECTION — every [MANDATORY stage/prod] item must be configured.
# Startup fails closed when anything is missing or an unsafe provider is set.
# =============================================================================

# --- Control plane (no PII) ---------------------------------------------------
# [MANDATORY stage/prod] one of the two; control-plane app requires the database URL
CONTROL_PLANE_DATABASE_URL=
CONTROL_PLANE_URL=
# [MANDATORY stage/prod for control-plane] admin API bearer token
CONTROL_PLANE_ADMIN_TOKEN=
CONTROL_PLANE_SUPABASE_URL=
CONTROL_PLANE_SUPABASE_ANON_KEY=
# Service-role key stays server-side; never expose to frontend:
CONTROL_PLANE_SUPABASE_SERVICE_ROLE_KEY=

# --- Tenant/data-plane resolver ------------------------------------------------
TENANT_RESOLVER_CACHE_TTL_SECONDS=60
# [MANDATORY stage/prod] must remain true (fail closed on unknown domains)
TENANT_RESOLVER_FAIL_CLOSED=true
# Forbidden in stage/prod:
# ALLOW_DEMO_TENANT=false

# --- Data plane access (api/worker) ---------------------------------------------
# [MANDATORY stage/prod] acknowledges the per-tenant service key convention:
# keys are read from DATA_PLANE_SERVICE_KEY__{TENANT_SLUG}__{ENVIRONMENT}
DATA_PLANE_SERVICE_KEY_SOURCE=env
# Single-tenant deployments may set a direct database URL instead:
DATA_PLANE_DATABASE_URL=
# Example per-tenant key reference (name pattern only, value from secret store):
# DATA_PLANE_SERVICE_KEY__DEMOKOMMUN__PROD=

# --- Auth ----------------------------------------------------------------------
# [MANDATORY stage/prod] entra_id | oidc | saml (supabase_auth only as
# local/demo/pilot fallback; header-proxy only behind a trusted internal proxy)
AUTH_PROVIDER=supabase_auth
# [MANDATORY stage/prod when AUTH_PROVIDER is entra_id/oidc/saml]
AUTH_ISSUER=
AUTH_CLIENT_ID=
AUTH_AUDIENCE=
AUTH_JWKS_URI=
# Client secret for the OIDC authorization code flow (web login):
AUTH_CLIENT_SECRET=
# [MANDATORY stage/prod for web] session cookie encryption secret
SESSION_SECRET=
# Header auth is disabled by default. Only enable behind a verified internal
# auth proxy that signs requests with the shared secret:
INTERNAL_AUTH_PROXY_TRUSTED=false
INTERNAL_AUTH_PROXY_SECRET=

# --- Documents / storage --------------------------------------------------------
# [MANDATORY stage/prod] supabase | s3 (local is forbidden in stage/prod)
DOCUMENT_STORAGE_PROVIDER=local
# [MANDATORY stage/prod] clamav | external-api (disabled-local is forbidden)
MALWARE_SCANNER_PROVIDER=disabled-local
DOCUMENT_MAX_UPLOAD_BYTES=26214400

# --- Audit / data access logs ----------------------------------------------------
# [MANDATORY stage/prod] must be postgres (in-memory is forbidden)
AUDIT_SINK=
DATA_ACCESS_SINK=

# --- Worker / queue ---------------------------------------------------------------
# [MANDATORY stage/prod] postgres | redis (in-memory is forbidden)
QUEUE_PROVIDER=
# [MANDATORY stage/prod] queue connection URL
WORKER_QUEUE_URL=
# Forbidden in stage/prod: WORKER_MODE=noop
WORKER_MODE=queue

# --- Release signing ---------------------------------------------------------------
# [MANDATORY stage/prod] ed25519 public key (PEM or base64 PEM) used to verify
# releases; unsigned releases are refused in stage/prod
RELEASE_SIGNING_PUBLIC_KEY=
# Private key is only present in the release pipeline, never on app servers:
# RELEASE_SIGNING_PRIVATE_KEY=

# --- Backups -------------------------------------------------------------------------
# [MANDATORY stage/prod] named backup provider/strategy, e.g. supabase-pitr,
# pgbackrest, managed-postgres
BACKUP_PROVIDER=

# --- UBM transport ----------------------------------------------------------------------
# Official UBM transport does not exist yet. This must remain "disabled" in
# every environment; any other value refuses startup.
UBM_OFFICIAL_TRANSPORT=disabled

# --- Demo/local data plane only -----------------------------------------------------------
DEMO_SUPABASE_URL=
DEMO_SUPABASE_ANON_KEY=
DEMO_SUPABASE_SERVICE_ROLE_KEY=

# --- Audit/SIEM export (optional) -----------------------------------------------------------
SIEM_EXPORT_ENABLED=false
SIEM_EXPORT_ENDPOINT=

# --- Billing, no citizen data (optional) ------------------------------------------------------
BILLING_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
