# UBM Klar environment example
# Never commit real secrets.

NODE_ENV=development
APP_NAME="UBM Klar"
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# Control plane, no PII
CONTROL_PLANE_DATABASE_URL=
CONTROL_PLANE_SUPABASE_URL=
CONTROL_PLANE_SUPABASE_ANON_KEY=
CONTROL_PLANE_SUPABASE_SERVICE_ROLE_KEY=

# Tenant/data-plane resolver
TENANT_RESOLVER_CACHE_TTL_SECONDS=60
TENANT_RESOLVER_FAIL_CLOSED=true

# Demo/local data plane only
DEMO_SUPABASE_URL=
DEMO_SUPABASE_ANON_KEY=
DEMO_SUPABASE_SERVICE_ROLE_KEY=

# Auth providers
ENTRA_CLIENT_ID=
ENTRA_ISSUER=
SAML_METADATA_URL=
OIDC_ISSUER=
OIDC_CLIENT_ID=

# Storage / documents
DOCUMENT_STORAGE_PROVIDER=supabase
MALWARE_SCANNER_PROVIDER=disabled-local

# Workers
WORKER_QUEUE_URL=

# Audit/SIEM
SIEM_EXPORT_ENABLED=false
SIEM_EXPORT_ENDPOINT=

# Billing, no citizen data
BILLING_PROVIDER=manual
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
